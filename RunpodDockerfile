FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# Create ubuntu user with sudo access
RUN useradd -m -s /bin/bash ubuntu && \
    apt-get update && \
    apt-get install -y sudo && \
    echo "ubuntu ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Clone the repo
RUN git clone https://github.com/vibekernels/modded-nanogpt-vk.git /home/ubuntu/modded-nanogpt-vk && \
    chown -R ubuntu:ubuntu /home/ubuntu/modded-nanogpt-vk

WORKDIR /home/ubuntu/modded-nanogpt-vk

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir datasets tiktoken

# Download pre-tokenized FineWeb data (9 chunks = 900M tokens)
RUN python data/cached_fineweb10B.py 9

# Ensure ubuntu owns everything
RUN chown -R ubuntu:ubuntu /home/ubuntu

USER ubuntu
WORKDIR /home/ubuntu/modded-nanogpt-vk

CMD ["/bin/bash"]
